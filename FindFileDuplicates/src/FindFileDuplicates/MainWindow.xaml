<Window x:Class="FindFileDuplicates.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MainWindow" Height="350" Width="525">

    <DockPanel LastChildFill="True" Margin="5">
        <DockPanel LastChildFill="True" VerticalAlignment="Top" DockPanel.Dock="Top">
            <Button
                Name="chooseFolderButton"
                Margin="3,0,0,0"
                DockPanel.Dock="Right" 
                Content="Choose a folder.." 
                HorizontalAlignment="Right" 
                VerticalAlignment="Center" Click="ChooseFolderButton_Click"/>

            <TextBox
                Name="pathTextBox"
                IsReadOnly="True"
                VerticalAlignment="Center"/>

        </DockPanel>
        
        <StackPanel
            Margin="0, 5"
            Orientation="Horizontal" DockPanel.Dock="Top">
            <TextBlock 
                Text="Use specified number of file bytes for comparison (0 for whole content): "/>
            <TextBox
                Width="70"
                Name="comparisonBytesCountTextBox" 
                Text="1024"/>
        </StackPanel>
        
        <TextBlock 
            Name="statusTextBlock" 
            DockPanel.Dock="Top"/>

        <ProgressBar
            DockPanel.Dock="Top"
            Name="progressBar"
            Visibility="Collapsed"
            IsIndeterminate="True" Height="15"/>

        <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
            <TextBlock Text="Files indexed: "/>
            <TextBlock 
                Name="filesIndexedTextBlock" 
                Text="0"
                DockPanel.Dock="Top"/>
        </StackPanel>

        <StackPanel 
            Orientation="Horizontal" 
            DockPanel.Dock="Top">
            <TextBlock Text="Hashes computed: "/>
            <TextBlock 
                Name="hashesComputedTextBlock" 
                Text="0"
                DockPanel.Dock="Top"/>
        </StackPanel>
        
        <TextBlock
            Margin="0,10,0,0"
                DockPanel.Dock="Top"
                Text="Duplicate files:"/>
        
        <ListBox Name="duplicatesList">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel 
                            Margin="0, 10"
                            Background="LightGray" 
                            HorizontalAlignment="Stretch">
                        <TextBlock 
                            Margin="3"
                            Text="{Binding Path=[0].Length, StringFormat='File length {0}'}"
                            FontWeight="Bold"/>
                        <ItemsControl
                                Margin="3"
                                ItemsSource="{Binding}">
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
